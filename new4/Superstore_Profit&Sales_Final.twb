      <repository-location derived-from='https://public.tableau.com/workbooks/SuperStoreSampleDataAnalysis-ProfitandDiscountAnalysis/ProfitRatioandDiscountperState?rev=' id='18435864' path='/workbooks/SuperStoreSampleDataAnalysis-ProfitandDiscountAnalysis' revision='' />
